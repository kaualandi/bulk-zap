# --- Database ---
DATABASE_URL=postgres://bulkzap:bulkzap@localhost:5432/bulkzap

# --- Redis (BullMQ) ---
# Dev: instale localmente via `brew install redis` (mac) ou `apt install redis-server` (linux)
# e suba com `brew services start redis` ou `sudo systemctl start redis`.
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=3000
API_HOST=0.0.0.0

# Origens permitidas pelo CORS (Next.js dev roda em 3001)
CORS_ORIGINS=http://localhost:3001

# --- Resend (emails de alerta) ---
RESEND_API_KEY=
ALERT_EMAIL_FROM=alerts@example.com

# --- IA (Anthropic) ---
# Sem essa chave, endpoints /ai/* devolvem 503 e UI esconde botões/badges.
# Obtenha em https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Bull Board (dashboard das filas BullMQ) ---
# Montado na mesma porta do API em /admin/queues
# Se USER e PASS estiverem vazios, o painel NÃO sobe (failsafe).
BULL_BOARD_USER=
BULL_BOARD_PASS=

# --- Cifra dos tokens Cloud API (32 bytes hex) ---
TOKEN_ENCRYPTION_KEY=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3000
# URL pública do app web (usada em links de e-mail: verificação, reset de senha)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- Better Auth (autenticação email+senha, multi-tenant) ---
# Segredo para assinar sessões/tokens. Gere com: openssl rand -base64 32
# Obrigatório em produção (a API não sobe sem ele); em dev usa fallback inseguro.
BETTER_AUTH_SECRET=
# URL base da API onde o Better Auth está montado
BETTER_AUTH_URL=http://localhost:3000
# Remetente dos e-mails de auth (verificação + reset), enviados via Resend
AUTH_EMAIL_FROM=auth@example.com

# --- Mercado Pago (assinatura recorrente em BRL) ---
# Access token da conta MP (preapproval/assinatura + pagamentos de overage)
MP_ACCESS_TOKEN=
# Segredo do webhook MP para validar a assinatura das notificações.
# Obrigatório em produção: sem ele os webhooks são rejeitados (em dev são aceitos com aviso).
MP_WEBHOOK_SECRET=
# Public key do MP usada no frontend (checkout/brick)
NEXT_PUBLIC_MP_PUBLIC_KEY=
